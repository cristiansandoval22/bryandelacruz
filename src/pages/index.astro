---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero/hero.astro';
import Header from '@components/sections/Header/Header.astro';
import AboutMe from '@components/sections/About/AboutMe.astro';
import Services from '@components/sections/Services/Services.astro';
import PortfolioSection from '@components/sections/Portfolio/PortfolioSection.astro';
// import { component } from 'sanity/structure';


Astro.response.headers.set(
 "Cache-Control",
 "public, s-maxage=300, stale-while-revalidate=3600"
);

