<article class="portfolio__card">
    <div class="portfolio__media">
        <img src={urlFor(item.thumbnail).width(500).url()} alt={item.title} />

        <a
            href={normalizeVideoUrl(item.videoUrl)}
            class="portfolio__play glightbox"
            data-gallery="portfolio"
            data-type="video"
        >
            <span class="portfolio__triangle"></span>
        </a>
    </div>

    <div class="portfolio__info">
        <p class="portfolio__brand">{item.brand?.title}</p>
        <h3 class="portfolio__title">{item.title}</h3>
        <p class="portfolio__description">{item.description}</p>
    </div>
</article>
