---
import { urlFor } from "@lib/sanity";

interface Props {
    item: any;
}

const { item } = Astro.props;

function normalizeVideoUrl(url: string) {
    if (url.includes("youtube.com/shorts/")) {
        const id = url.split("/shorts/")[1].split("?")[0];
        return `https://www.youtube.com/watch?v=${id}`;
    }

    return url;
}
